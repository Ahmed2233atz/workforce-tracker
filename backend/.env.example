# Server
PORT=3001
NODE_ENV=production

# Security — CHANGE THIS to a long random string in production!
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars

# Database path (Railway: set to /data/workforce.db)
DATABASE_PATH=./workforce.db

# Frontend URL for CORS (your Vercel URL, e.g. https://workforce-tracker.vercel.app)
FRONTEND_URL=http://localhost:5173

# Email (optional — for daily/weekly reports)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your@email.com
EMAIL_PASS=your-app-password
EMAIL_FROM=WorkForce Tracker <your@email.com>
ADMIN_EMAIL=admin@yourcompany.com
