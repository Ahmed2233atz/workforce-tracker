{
  "name": "workforce-tracker-backend",
  "version": "1.0.0",
  "main": "server.js",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "cd ../frontend && npm install && npm run build && xcopy /E /I /Y dist ..\\backend\\public > nul 2>&1 || cp -r dist ../backend/public",
    "start": "node --experimental-sqlite server.js",
    "dev": "nodemon --exec \"node --experimental-sqlite\" server.js",
    "seed": "node --experimental-sqlite seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.9"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
